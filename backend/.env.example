# ===========================
# Bank Sampah Backend Config
# ===========================

# Server
APP_PORT=8080
APP_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=bank_sampah
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# HMAC
HMAC_TIMESTAMP_TOLERANCE=300

# Worker Pool
WORKER_POOL_SIZE=10
CALLBACK_MAX_RETRIES=5
